generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  images    Image[]

  @@index([name])
}

model Image {
  id          String    @id @default(cuid())
  url         String
  pathname    String
  filename    String
  contentType String
  size        Int
  title       String?
  notes       String?
  createdAt   DateTime  @default(now())
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([categoryId, createdAt])
  @@index([filename])
}
